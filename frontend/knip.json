{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/main.ts", "vite.config.ts", "vitest.config.ts", "src/**/*.test.ts"],
  "project": ["src/**/*.{ts,svelte}", "vite.config.ts", "vitest.config.ts"],
  "ignore": ["bindings/**", "dist/**"],
  "ignoreDependencies": ["@types/dompurify", "tailwindcss", "tslib"],
  "ignoreIssues": {
    "src/lib/**": ["exports", "types"]
  }
}
